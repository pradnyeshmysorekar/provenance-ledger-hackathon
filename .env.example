# Backblaze B2 credentials
# Get these from: B2 web console -> Application Keys -> Generate New Application Key
B2_KEY_ID=your_b2_key_id_here
B2_APP_KEY=your_b2_application_key_here
B2_BUCKET_NAME=provenance-ledger-hackathon
# Region your bucket lives in — check the B2 web console (bucket details page)
# if you get a "wrong region" error; eu-central-003 is the current default here.
B2_REGION=eu-central-003

# Google (Imagen) credentials — primary image provider
# Get this free at https://aistudio.google.com -> Get API key
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_API_KEY=your_google_api_key_here

# NVIDIA NIM credentials
# Get this from: https://build.nvidia.com -> API Keys -> Generate API Key (starts with nvapi-)
# NOTE: confirm the exact expected env var name against the genblaze-nvidia README
# after `pip install genblaze-nvidia` — it is very likely NVIDIA_API_KEY or NVAPI_KEY.
# Set BOTH below to be safe; unused one is harmless.
NVIDIA_API_KEY=nvapi-your_key_here
NVAPI_KEY=nvapi-your_key_here
